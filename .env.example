# Copy to .env and fill in. Any OpenAI-compatible endpoint works.

# Required: API key for the endpoint (e.g. an OpenRouter key, sk-or-...).
CLAUSELENS_API_KEY=

# Optional — defaults shown.
# CLAUSELENS_BASE_URL=https://openrouter.ai/api/v1
# CLAUSELENS_MODEL=google/gemma-4-31b-it:free

# Optional: minimum seconds between requests. Set to ~3 on free tiers to stay
# under the per-minute cap on long eval runs (0 = no spacing).
# CLAUSELENS_MIN_INTERVAL=0
